# X OAuth 2.0 app credentials — from the X Developer Portal.
# X_CLIENT_ID must be the OAuth 2.0 "Client ID", NOT the OAuth 1.0a "Access Token"
# (those look like 1234567890-AbCdEf...).
X_CLIENT_ID=
X_CLIENT_SECRET=

# Random secret for signing session cookies.  Generate with: openssl rand -hex 32
SESSION_SECRET=

# Callback URL registered in the X Developer Portal (exact string match required).
# Recommended for local dev: use the Vite proxy so login + callback stay on the same origin.
X_REDIRECT_URI=http://localhost:5173/oauth/callback

# Post-OAuth redirect and CORS origin — must match how you open the UI.
FRONTEND_URL=http://localhost:5173

# OAuth2 scopes — like.read is required for engagement analysis (liking_users endpoint).
# X_OAUTH_SCOPES=tweet.read users.read like.read offline.access

# SQLite database path.
# DB_PATH=thread_helper.db

# Background metric-polling interval in seconds. Re-fetches every active-contest
# post's public metrics on this cadence. Minimum 300s (clamped at startup); default 3600.
# POLL_INTERVAL_SECONDS=3600

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Rate limiting — slowapi format: N/period (e.g. 10/minute, 100/hour).
RATE_LIMIT_SUBMISSIONS=10/minute
RATE_LIMIT_LEADERBOARD=60/minute
RATE_LIMIT_AUTH=5/minute

# Helius (or other) Solana RPC endpoint for stake verification.
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Feature flags (from shilljudge_core; all default to off/safe).
# CORE_ENABLE_PREMIUM=0
# CORE_ENABLE_PRIVATE_CONTESTS=0
# CORE_ENABLE_ADVANCED_BOT_FILTER=0
# CORE_ENABLE_AI_SCORING=0
# CORE_ENABLE_TOKEN_GATING=1

# Seed the database with demo data on startup (dev only).
# SEED_DB=0
